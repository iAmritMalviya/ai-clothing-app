DATABASE_URL=postgresql://user:password@localhost:5432/clothing_app
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
PUBLIC_URL=http://localhost:3001

# AI Provider Keys (only needed for providers you use)
FAL_KEY=your-fal-ai-key-here
GEMINI_API_KEY=your-google-ai-api-key-here

# Per-operation provider selection (fal | gemini)
# Defaults: bg_removal=fal, tryon=fal, scene_gen=gemini
AI_PROVIDER_BG_REMOVAL=fal
AI_PROVIDER_TRYON=fal
AI_PROVIDER_SCENE_GEN=gemini
